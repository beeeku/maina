---
/**
 * Hero — feature 050. All copy sourced from `src/data/landing.ts`;
 * no string in this component may originate here (enforced by the
 * Phase-9 CI grep check). Right column is the 52-second auto-playing
 * terminal rendered by `HeroTerminal.astro`.
 */
import { HERO } from '../data/landing';
import HeroTerminal from './HeroTerminal.astro';
---

<section class="hero-v2" id="hero">
  <div class="hero-v2__col hero-v2__col--copy">
    <p class="hero-v2__eyebrow">{HERO.eyebrow}</p>
    <h1 class="hero-v2__headline">
      <span>{HERO.headlineLine1}</span>
      <span class="hero-v2__headline-accent">{HERO.headlineLine2}</span>
    </h1>
    <p class="hero-v2__sub">{HERO.sub}</p>

    <div class="hero-v2__install" id="install">
      <label class="hero-v2__install-label" for="hero-install">Install</label>
      <div class="hero-v2__install-row">
        <input
          id="hero-install"
          class="hero-v2__install-input"
          type="text"
          readonly
          value={HERO.installCommand}
          aria-label="Install command — read-only, select to copy"
        />
        <button
          class="hero-v2__install-copy"
          type="button"
          data-copy-target="#hero-install"
          aria-label="Copy install command"
        >
          Copy
        </button>
      </div>
    </div>

    <ul class="hero-v2__affordances">
      {HERO.affordances.map((a) => (
        <li class="hero-v2__affordance">
          {a.kind === 'scroll' && 'target' in a ? (
            <a href={a.target}>{a.label}</a>
          ) : a.kind === 'link' && 'href' in a ? (
            <a href={a.href} rel="noopener">{a.label}</a>
          ) : (
            <span>{a.label}</span>
          )}
        </li>
      ))}
    </ul>
  </div>

  <div class="hero-v2__col hero-v2__col--terminal" aria-hidden="false">
    <HeroTerminal />
  </div>
</section>

<script is:inline>
  (function () {
    // Copy-to-clipboard. Guarded by feature detection so no-JS / no-clipboard
    // browsers still let the reader select + copy from the readonly input.
    var btn = document.querySelector('.hero-v2__install-copy');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var sel = btn.getAttribute('data-copy-target');
      if (!sel) return;
      var input = document.querySelector(sel);
      if (!input) return;
      var value = input.value;
      var done = function () {
        var original = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(function () { btn.textContent = original; }, 1600);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(value).then(done, function () {
          input.select();
          document.execCommand('copy');
          done();
        });
      } else {
        input.select();
        document.execCommand('copy');
        done();
      }
    });
  })();
</script>
