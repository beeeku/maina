---
/**
 * DemoBooking — lightweight "book a demo" card. Scheduler = Calendly
 * public link (opens in a new tab). Mailto is kept as the fallback
 * if the Calendly slug ever disappears.
 */
import { DEMO } from '../data/cloud-landing';

const href = DEMO.scheduler;
---

<section class="demo" id="demo">
  <div class="demo__card">
    <span class="section-eyebrow">// demo</span>
    <h2 class="demo__title">{DEMO.header}</h2>
    <p class="demo__body">{DEMO.body}</p>
    <a class="demo__cta" href={href} target="_blank" rel="noopener">{DEMO.ctaLabel}</a>
  </div>
</section>

<style is:global>
  .demo {
    max-width: 720px;
    margin: 60px auto;
    padding: 0 24px;
  }

  .demo__card {
    background: var(--color-bg-elev);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    padding: 28px 28px 32px;
    text-align: center;
  }

  .demo__title {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 28px);
    margin: 8px 0 10px;
    color: var(--color-ink);
  }

  .demo__body {
    margin: 0 auto 20px;
    max-width: 540px;
    color: var(--color-ink-muted);
    font-size: 14.5px;
    line-height: 1.6;
  }

  .demo__cta {
    display: inline-block;
    padding: 11px 22px;
    background: var(--color-accent);
    color: var(--color-accent-ink);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    border-radius: var(--radius);
    text-decoration: none;
    transition: filter 140ms ease;
  }

  .demo__cta:hover { filter: brightness(1.06); }
</style>
